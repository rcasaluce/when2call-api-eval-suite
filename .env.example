# =============================================================================
# When2Call - environment variables (example)
# Copy to: .env
# =============================================================================

# ---------------------------------------------------------------------------
# Provider tokens (the main ones your script/config plausibly needs)
# ---------------------------------------------------------------------------

# JRC provider token (used by CFG["providers"]["jrc"]["token"])
TOKEN_JRC=

# Gemini provider token (used by CFG["providers"]["gemini"]["token"])
TOKEN_GEMINI=

# ---------------------------------------------------------------------------
# Optional runtime override
# ---------------------------------------------------------------------------

# Optional run key override (if your w2c_config maps env -> CFG["run"]["run_key"])
RUN_KEY=

# ---------------------------------------------------------------------------
# Optional aliases (ONLY if your w2c_config supports these aliases)
# Keep commented unless you know your loader maps them.
# ---------------------------------------------------------------------------

# OPENAI_API_KEY=
# GEMINI_API_KEY=